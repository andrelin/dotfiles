{
  "name": "dotfiles-website",
  "version": "0.0.0",
  "private": true,
  "description": "Docusaurus site for the dotfiles repo. Source docs (README.md, TIPS.md, tips/*, init/README.md, source/README.md) are gathered into docs-generated/ at build time.",
  "scripts": {
    "gather": "tsx scripts/gather-docs.ts",
    "prestart": "npm run gather",
    "prebuild": "npm run gather",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "serve": "docusaurus serve",
    "clear": "docusaurus clear",
    "swizzle": "docusaurus swizzle",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@docusaurus/core": "^3.10.1",
    "@docusaurus/preset-classic": "^3.10.1",
    "@mdx-js/react": "^3.1.1",
    "clsx": "^2.1.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.10.1",
    "@docusaurus/tsconfig": "^3.10.1",
    "@docusaurus/types": "^3.10.1",
    "@types/node": "^22.19.17",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  },
  "browserslist": {
    "production": [">0.5%", "not dead", "not op_mini all"],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=18.20.8"
  }
}
